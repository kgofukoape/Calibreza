                className="bg-[#C9922A] text-black px-10 py-3 rounded-sm font-black uppercase tracking-widest text-[13px] hover:brightness-110 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
              >
                {saving
                  ? uploadingImages
                    ? 'Uploading Images...'
                    : 'Saving...'
                  : 'Save Profile'}
              </button>
            </div>

          </div>
        </form>
      </main>
    </div>
  );
}
</file>

