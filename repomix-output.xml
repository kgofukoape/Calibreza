              {club.email && <a href={`mailto:${club.email}`} className="border border-white/20 font-black uppercase tracking-widest text-[12px] px-5 py-2.5 rounded-sm hover:bg-white/5">✉ Email</a>}
            </div>
          </div>
        </div>
      </div>

      {/* LIVE STATUS + WEATHER BAR */}
