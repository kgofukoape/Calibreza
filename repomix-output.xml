                    <div className="text-5xl font-black text-[#C9922A] mb-2">{dealer.rating?.toFixed(1) || '0.0'}</div>
                    <div className="text-[13px] text-[#8A8E99] font-bold uppercase tracking-widest">{dealer.review_count || 0} reviews</div>
