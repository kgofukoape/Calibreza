                                <p className={`text-[9px] mb-1 ${isSelected ? 'text-black/70' : 'text-[#8A8E99]'}`}>{day.month}</p>
                                {day.isOpen && day.sched?.open_time && <p className={`text-[8px] font-bold ${isSelected ? 'text-black/70' : 'text-[#8A8E99]/70'}`}>{day.sched.open_time}</p>}
                              </button>
                            );
                          })}
