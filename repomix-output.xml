                    </div>
                  )}
                  <div>
                    <p className="text-[#8A8E99] text-[11px] font-black uppercase tracking-widest mb-1">Physical Address</p>
                    <p className="text-xl font-bold leading-tight">{dealer.address || `${dealer.city}, ${dealer.province}`}</p>
                  </div>
                  {dealer.website && (
                    <div>
