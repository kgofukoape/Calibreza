              <span className={`text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-sm ${
                isTrial ? 'bg-[#2A9C6E]/15 text-[#2A9C6E] border border-[#2A9C6E]/30' :
                isActive ? 'bg-[#C9922A]/15 text-[#C9922A] border border-[#C9922A]/30' :
