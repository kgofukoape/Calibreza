                            <div className="flex-1 flex items-center gap-4 flex-wrap">
                              <span style={{ fontFamily: "'Barlow Condensed',sans-serif" }} className="text-[#C9922A] font-black text-[14px]">{day.open_time} – {day.close_time}</span>
