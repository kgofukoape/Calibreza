            </p>
            <p className="text-sm text-[#8A8E99]">
              Redirecting to login page...
            </p>
          </div>
        </main>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#0D0F13] text-[#F0EDE8]">
      <Navbar />

      <main className="max-w-[900px] mx-auto px-6 py-20">
