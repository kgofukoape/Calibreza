'use client';

import React, { useState, useEffect } from 'react';
import Link from 'next/link';
import { useRouter } from 'next/navigation';
import { supabase } from '@/lib/supabase';

const PLANS = [
  {
    id: 'free',
    label: 'Free',
    price: 0,
    priceLabel: 'R0',
    billingLabel: 'forever',
    listingLimit: 5,
    listingLimitLabel: '5 listings',
