        {/* Dismiss */}
        <button
          onClick={() => setDismissed(true)}
          className="w-6 h-6 rounded-full bg-[#191C23] border border-white/10 flex items-center justify-center text-[#8A8E99] hover:text-white hover:border-white/20 transition-all text-[10px]"
          title="Dismiss">
          ×
        </button>

        {/* Main CTA */}
        <Link href="/advisor"
          className="flex items-center gap-2 bg-[#C9922A] text-black px-4 py-3 rounded-sm shadow-[0_4px_20px_rgba(201,146,42,0.4)] hover:brightness-110 transition-all group">
          <span className="text-lg">🎯</span>
          <div className="flex flex-col">
            <span style={{ fontFamily: "'Barlow Condensed', sans-serif" }}
              className="font-black uppercase tracking-widest text-[12px] leading-none">
              Firearm Advisor
            </span>
            <span className="text-[9px] font-bold text-black/70 leading-none mt-0.5">AI-Powered · Free</span>
