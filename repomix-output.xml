  province_id: string;
  city: string;
  seller_id: string;
  listing_type: 'private' | 'dealer';
  licence_type: string;
  action_type: string;
  capacity: string;
  barrel_length: string;
  overall_length: string;
  included_items: string[];
  status: string;
  is_featured: boolean;
  views_count: number;
  images: string[];
  created_at: string;
  updated_at: string;
